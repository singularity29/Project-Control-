{
  "manifest_version": 3,
  "name": "Project Control",
  "version": "2.2.0",
  "description": "Cognitive control and 18+ content blocker.",
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["tf.min.js", "nsfwjs.min.js", "content.js"]
    }
  ]
}