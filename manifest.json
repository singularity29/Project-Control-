{
  "manifest_version": 3,
  "name": "Project Control",
  "version": "3.0.0",
  "description": "Cognitive control and Offscreen AI Blocker.",
  "permissions": [
    "storage",
    "offscreen"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ]
}